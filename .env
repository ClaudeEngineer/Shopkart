# ═══════════════════════════════════════════════════
#   ShopKart — Backend Environment Variables
#   Copy this file:  cp .env.example .env
#   Then fill in your values below
# ═══════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────
# Option 1: Local MongoDB (MongoDB must be running)
MONGO_URI=mongodb://flipkart_2026:2026flipkart@ac-szvw6kq-shard-00-00.tjzr21p.mongodb.net:27017,ac-szvw6kq-shard-00-01.tjzr21p.mongodb.net:27017,ac-szvw6kq-shard-00-02.tjzr21p.mongodb.net:27017/?ssl=true&replicaSet=atlas-kwmdsz-shard-0&authSource=admin&appName=Flipkart
# MONGO_URI=mongodb+srv://flipkart_2026:2026flipkart@flipkart.tjzr21p.mongodb.net/Flipkart?appName=Flipkart
# Option 2: MongoDB Atlas (Cloud) — uncomment & fill:
# MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/shopkart?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=shopkart_super_secret_key_change_this_in_production
JWT_EXPIRE=30d

# ── Frontend URL (for CORS) ──────────────────────────
CLIENT_URL=https://shopcartshopp.netlify.app

